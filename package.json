{
  "name": "smart-anti-sedentary",
  "version": "1.0.0",
  "description": "Smart Anti-Sedentary App - Intelligent break reminder based on actual work time",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect=5858",
    "test": "electron src/test-idle-electron.js",
    "postinstall": "electron-builder install-app-deps",
    "build": "electron-builder --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:all": "electron-builder --mac --win --publish never"
  },
  "keywords": [
    "health",
    "productivity",
    "break-reminder",
    "anti-sedentary"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "desktop-idle": "^1.3.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.smartantisedentary.app",
    "productName": "智能防久坐",
    "copyright": "Copyright © 2026",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.healthcare-fitness",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "智能防久坐"
    }
  }
}
